@model List<ConviAppWeb.Models.ENGasto>
@{
    ViewData["Title"] = "Gastos";
    var userRole = ViewBag.UserRole as string ?? "Basico";
    var showAds = ConviAppWeb.Services.PlanService.ShowAds(userRole);
}

<div class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="dash-tabs">
        <a href="/Dashboard/Index" class="dash-tab">📊 Resumen</a>
        <a href="/Dashboard/Tareas" class="dash-tab">✅ Tareas</a>
        <a href="/Dashboard/Gastos" class="dash-tab active">💸 Gastos</a>
        <a href="/Dashboard/Mensajes" class="dash-tab">💬 Mensajes</a>
        <a href="/Dashboard/Reservas" class="dash-tab">📅 Reservas</a>
        <a href="/Dashboard/Incidencias" class="dash-tab">🔧 Incidencias</a>
        <a href="/Dashboard/ContratosYPagos" class="dash-tab">📄 Contratos</a>
        <a href="/Dashboard/Documentos" class="dash-tab">📎 Documentos</a>
        <a href="/Dashboard/MisPisos" class="dash-tab">🏠 Mis Pisos</a>
    </div>

    @if (showAds) { <partial name="_AdBanner" /> }

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h2>💸 Gastos Comunes</h2>
        @if (Model != null && Model.Any())
        {
            <div style="font-size: 1.5rem; font-weight: 800; font-family: 'Outfit', sans-serif; color: var(--danger);">
                Total: @Model.Sum(e => e.Importe).ToString("0.00") €
            </div>
        }
    </div>

    <!-- Add Expense Form -->
    <div class="glass-card" style="margin-bottom: 24px;">
        <h4 style="margin-top: 0; color: var(--primary-light);">➕ Nuevo gasto</h4>
        <form method="post" action="/Dashboard/AddExpense" style="display: flex; gap: 12px; flex-wrap: wrap;">
            <input type="text" name="concepto" class="form-input" placeholder="Concepto" required style="flex: 2; min-width: 200px;" />
            <input type="number" name="importe" step="0.01" min="0.01" class="form-input" placeholder="Importe (€)" required style="flex: 1; min-width: 120px;" />
            <button type="submit" class="btn btn-primary btn-sm">Añadir</button>
        </form>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="glass-card" style="text-align: center; padding: 3rem; color: var(--text-muted);">
            <div style="font-size: 3rem; margin-bottom: 16px;">💸</div>
            <p>No hay gastos registrados todavía.</p>
        </div>
    }
    else
    {
        <div class="glass-card" style="padding: 0; overflow: hidden;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Concepto</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th style="text-align: right;">Importe</th>
                        <th style="width: 50px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td style="font-weight: 500;">@e.Concepto</td>
                            <td style="color: var(--text-muted);">@e.Fecha.ToShortDateString()</td>
                            <td><span style="color: @(e.Pagado ? "var(--success)" : "var(--warning)")">@(e.Pagado ? "✅ Pagado" : "⏳ Pendiente")</span></td>
                            <td style="text-align: right; font-weight: 700; color: var(--danger);">@e.Importe.ToString("0.00") €</td>
                            <td>
                                <form method="post" action="/Dashboard/DeleteExpense" style="display: inline;">
                                    <input type="hidden" name="id" value="@e.Id" />
                                    <button type="submit" style="background: none; border: none; cursor: pointer; color: #f87171;" onclick="return confirm('¿Eliminar?')">🗑</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
