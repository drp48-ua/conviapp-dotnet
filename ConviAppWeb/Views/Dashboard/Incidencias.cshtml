@model List<ConviAppWeb.Models.ENIncidencia>
@{
    ViewData["Title"] = "Incidencias";
    var userRole = ViewBag.UserRole as string ?? "Basico";
    var showAds = ConviAppWeb.Services.PlanService.ShowAds(userRole);
    var locked = ViewBag.Locked == true;
}

<div class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="dash-tabs">
        <a href="/Dashboard/Index" class="dash-tab">📊 Resumen</a>
        <a href="/Dashboard/Tareas" class="dash-tab">✅ Tareas</a>
        <a href="/Dashboard/Gastos" class="dash-tab">💸 Gastos</a>
        <a href="/Dashboard/Mensajes" class="dash-tab">💬 Mensajes</a>
        <a href="/Dashboard/Reservas" class="dash-tab">📅 Reservas</a>
        <a href="/Dashboard/Incidencias" class="dash-tab active">🔧 Incidencias</a>
        <a href="/Dashboard/ContratosYPagos" class="dash-tab">📄 Contratos</a>
        <a href="/Dashboard/Documentos" class="dash-tab">📎 Documentos</a>
        <a href="/Dashboard/MisPisos" class="dash-tab">🏠 Mis Pisos</a>
    </div>

    @if (showAds) { <partial name="_AdBanner" /> }

    <h2 style="margin-bottom: 20px;">🔧 Incidencias</h2>

    @if (locked)
    {
        <partial name="_PlanLock" />
    }
    else
    {
        <!-- Report Incident Form -->
        <div class="glass-card" style="margin-bottom: 24px;">
            <h4 style="margin-top: 0; color: var(--primary-light);">➕ Reportar incidencia</h4>
            <form method="post" action="/Dashboard/ReportIncident" style="display: flex; gap: 12px; flex-wrap: wrap;">
                <input type="text" name="titulo" class="form-input" placeholder="Título" required style="flex: 1; min-width: 200px;" />
                <input type="text" name="descripcion" class="form-input" placeholder="Descripción detallada" required style="flex: 2; min-width: 200px;" />
                <button type="submit" class="btn btn-primary btn-sm">Reportar</button>
            </form>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="glass-card" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                <div style="font-size: 3rem; margin-bottom: 16px;">🔧</div>
                <p>No hay incidencias registradas. ¡Todo en orden!</p>
            </div>
        }
        else
        {
            <ul class="task-list">
                @foreach (var i in Model)
                {
                    var badgeClass = i.Estado?.ToLower() == "resuelta" ? "done" :
                                     i.Estado?.ToLower() == "en_progreso" ? "pending" : "open";
                    <li class="task-item">
                        <div class="task-info">
                            <div class="task-name">@i.Titulo</div>
                            <div class="task-meta">@(i.Descripcion ?? "") · @i.FechaReporte.ToShortDateString()</div>
                        </div>
                        <span class="status-badge @badgeClass">@(i.Estado ?? "abierta")</span>
                        @if (i.Estado != "resuelta")
                        {
                            <form method="post" action="/Dashboard/UpdateIncidentStatus" style="display: inline;">
                                <input type="hidden" name="id" value="@i.Id" />
                                @if (i.Estado == "abierta")
                                {
                                    <input type="hidden" name="status" value="en_progreso" />
                                    <button type="submit" class="btn btn-sm" style="background: rgba(245,158,11,0.1); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3);">▶ En progreso</button>
                                }
                                else
                                {
                                    <input type="hidden" name="status" value="resuelta" />
                                    <button type="submit" class="btn btn-sm" style="background: rgba(52,211,153,0.1); color: #34d399; border: 1px solid rgba(52,211,153,0.3);">✓ Resolver</button>
                                }
                            </form>
                        }
                    </li>
                }
            </ul>
        }
    }
</div>
