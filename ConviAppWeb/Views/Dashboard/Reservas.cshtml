@model List<ConviAppWeb.Models.ENReserva>
@{
    ViewData["Title"] = "Reservas";
    var userRole = ViewBag.UserRole as string ?? "Basico";
    var showAds = ConviAppWeb.Services.PlanService.ShowAds(userRole);
    var locked = ViewBag.Locked == true;
}

<div class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <div class="dash-tabs">
        <a href="/Dashboard/Index" class="dash-tab">📊 Resumen</a>
        <a href="/Dashboard/Tareas" class="dash-tab">✅ Tareas</a>
        <a href="/Dashboard/Gastos" class="dash-tab">💸 Gastos</a>
        <a href="/Dashboard/Mensajes" class="dash-tab">💬 Mensajes</a>
        <a href="/Dashboard/Reservas" class="dash-tab active">📅 Reservas</a>
        <a href="/Dashboard/Incidencias" class="dash-tab">🔧 Incidencias</a>
        <a href="/Dashboard/ContratosYPagos" class="dash-tab">📄 Contratos</a>
        <a href="/Dashboard/Documentos" class="dash-tab">📎 Documentos</a>
        <a href="/Dashboard/MisPisos" class="dash-tab">🏠 Mis Pisos</a>
    </div>

    @if (showAds) { <partial name="_AdBanner" /> }

    <h2 style="margin-bottom: 20px;">📅 Reservas de Zonas Comunes</h2>

    @if (locked)
    {
        <partial name="_PlanLock" />
    }
    else
    {
        <!-- Add Reservation Form -->
        <div class="glass-card" style="margin-bottom: 24px;">
            <h4 style="margin-top: 0; color: var(--primary-light);">➕ Nueva reserva</h4>
            <form method="post" action="/Dashboard/AddReservation" style="display: flex; gap: 12px; flex-wrap: wrap;">
                <input type="text" name="motivo" class="form-input" placeholder="Zona o motivo (ej: Lavadora, Salón)" required style="flex: 1; min-width: 150px;" />
                <input type="datetime-local" name="fechaInicio" class="form-input" required style="flex: 1; min-width: 180px;" />
                <input type="datetime-local" name="fechaFin" class="form-input" required style="flex: 1; min-width: 180px;" />
                <button type="submit" class="btn btn-primary btn-sm">Reservar</button>
            </form>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="glass-card" style="text-align: center; padding: 3rem; color: var(--text-muted);">
                <div style="font-size: 3rem; margin-bottom: 16px;">📅</div>
                <p>No hay reservas activas.</p>
            </div>
        }
        else
        {
            <ul class="task-list">
                @foreach (var r in Model)
                {
                    <li class="task-item">
                        <div class="task-info">
                            <div class="task-name">📍 @(r.Motivo ?? "Zona común")</div>
                            <div class="task-meta">@r.FechaInicio.ToString("g") → @r.FechaFin.ToString("g")</div>
                        </div>
                        <span class="status-badge active">@(r.Estado ?? "confirmada")</span>
                        <form method="post" action="/Dashboard/CancelReservation" style="display: inline;">
                            <input type="hidden" name="id" value="@r.Id" />
                            <button type="submit" class="btn btn-sm" style="background: rgba(248,113,113,0.1); color: #f87171; border: 1px solid rgba(248,113,113,0.3);" onclick="return confirm('¿Cancelar reserva?')">✕</button>
                        </form>
                    </li>
                }
            </ul>
        }
    }
</div>
