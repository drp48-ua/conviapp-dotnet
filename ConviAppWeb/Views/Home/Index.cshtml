@model List<ConviAppWeb.Models.Property>
@{
    ViewData["Title"] = "Inicio";
    ViewData["ActivePage"] = "Home";
    
    // Check if user logged in
    var userEmail = Context.Session.GetString("UserEmail");
    bool isLoggedIn = userEmail != null;
}

<style>
    /* Specific FlatManager Layout Styles */
    .dashboard-layout {
        display: flex;
        gap: 24px;
        padding-top: 24px;
        max-width: 1400px;
        margin: 0 auto;
    }
    .sidebar-left {
        width: 250px;
        flex-shrink: 0;
    }
    .main-content {
        flex: 1;
        min-width: 0;
    }
    .sidebar-right {
        width: 300px;
        flex-shrink: 0;
    }
    
    .flat-card {
        background: white;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        padding: 20px;
        margin-bottom: 24px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    
    .profile-card { text-align: center; }
    .profile-card img { width: 64px; height: 64px; border-radius: 50%; margin-bottom: 12px; }
    .profile-card h4 { margin: 0 0 4px; font-size: 1.1rem; }
    .profile-card p { color: #6b7280; font-size: 0.85rem; margin-bottom: 16px; }
    
    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        color: #4b5563;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 500;
        margin-bottom: 4px;
    }
    .menu-link:hover { background: #f3f4f6; color: #1e3a8a; }
    
    .welcome-banner {
        background: linear-gradient(135deg, #f0f4f8, #e0e7ff);
        border: 1px solid #c7d2fe;
        border-radius: 8px;
        padding: 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .welcome-banner h2 { margin: 0 0 8px; color: #1e3a8a; }
    .welcome-banner p { color: #4b5563; margin-bottom: 20px; max-width: 600px; }
    
    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }
    .service-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
        transition: all 0.2s;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: inherit;
    }
    .service-card:hover { border-color: #3b82f6; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .service-icon { font-size: 2rem; margin-bottom: 12px; }
    .service-card h4 { margin: 0 0 8px; font-size: 1rem; color: #1f2937; }
    .service-card p { font-size: 0.8rem; color: #6b7280; margin: 0; line-height: 1.4; }
    
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .summary-item {
        background: #f9fafb;
        border: 1px solid #f3f4f6;
        border-radius: 8px;
        padding: 16px;
    }
    .summary-item .label { font-size: 0.85rem; color: #6b7280; font-weight: 500; }
    .summary-item .value { font-size: 1.5rem; font-weight: 700; color: #111827; margin: 4px 0; }
    .summary-item .trend { font-size: 0.75rem; color: #10b981; font-weight: 500; }
    
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.3s ease; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    @@media (max-width: 900px) {
        .dashboard-layout {
            flex-direction: column;
        }
        .sidebar-left, .sidebar-right {
            width: 100%;
        }
        .summary-grid {
            grid-template-columns: 1fr;
        }
        .services-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>

<div class="dashboard-layout">
    <!-- LEFT SIDEBAR -->
    <div class="sidebar-left">
        @if (isLoggedIn)
        {
            <div class="flat-card profile-card">
                <img src="@(Context.Session.GetString("UserPhotoUrl") ?? "https://i.pravatar.cc/100?u=moni")" alt="Usuario" />
                <h4>@(Context.Session.GetString("UserName") ?? "Usuario")</h4>
                <p>@userEmail</p>
                <a href="/Account/Profile" class="btn btn-outline btn-sm" style="width:100%">Editar perfil</a>
            </div>
            
            <div class="flat-card" style="padding: 16px;">
                <h4 style="font-size: 0.9rem; color: #6b7280; margin-bottom: 12px; font-weight: 600; text-transform: uppercase;">Accesos rápidos</h4>
                <a href="#" onclick="switchMainTab('tareas'); return false;" class="menu-link"><span>✅</span> Mis tareas</a>
                <a href="#" onclick="switchMainTab('gastos'); return false;" class="menu-link"><span>💶</span> Mis gastos</a>
                <a href="#" class="menu-link"><span>🔧</span> Nueva incidencia</a>
                <a href="#" onclick="switchMainTab('reservas'); return false;" class="menu-link"><span>📅</span> Calendario</a>
            </div>
        }
        else
        {
            <div class="flat-card" style="background: linear-gradient(to bottom, #10b981, #059669); color: white; padding: 24px; text-align: center;">
                <h3 style="font-size: 1.2rem; margin-bottom: 8px;">Habitación Premium</h3>
                <p style="font-size: 0.85rem; color: #d1fae5; margin-bottom: 16px;">Encuentra las mejores habitaciones para estudiantes con todo incluido.</p>
                <button class="btn btn-outline btn-sm" style="color:white; border-color:rgba(255,255,255,0.4);">Ver pisos</button>
            </div>
            
            <div class="flat-card" style="background: #eff6ff; border-color: #bfdbfe; padding: 24px; text-align: center;">
                <h3 style="font-size: 1.2rem; color: #1e3a8a; margin-bottom: 8px;">Seguro de Estudiantes</h3>
                <p style="font-size: 0.85rem; color: #1e40af; margin-bottom: 16px;">Protege tus pertenencias en tu piso compartido desde solo 5€/mes.</p>
                <button class="btn btn-primary btn-sm" style="background:#3b82f6;">Más info</button>
            </div>
        }
    </div>

    <!-- MAIN INTERACTIVE AREA -->
    <div class="main-content">
        <!-- TAB INICIO -->
        <div id="tab-inicio" class="tab-content active">
            <div class="welcome-banner">
                <div>
                    <h2>¡Bienvenida a ConviApp!</h2>
                    <p>La forma más fácil de gestionar tu piso compartido de manera organizada.</p>
                    <div style="display: flex; gap: 12px;">
                        <button onclick="switchMainTab('pisos')" class="btn btn-primary">Ver mis pisos</button>
                        <button onclick="switchMainTab('tareas')" class="btn btn-outline" style="background:white">Ir a mis tareas</button>
                    </div>
                </div>
            </div>
            
            <h3 style="font-size: 1.1rem; margin-bottom: 16px; color: #1e3a8a;">Servicios principales</h3>
            
            <div class="services-grid">
                <a href="#" onclick="switchMainTab('pisos'); return false;" class="service-card">
                    <div class="service-icon">🏠</div>
                    <h4>Pisos</h4>
                    <p>Consulta y gestiona los pisos disponibles.</p>
                </a>
                <a href="#" onclick="switchMainTab('contratos'); return false;" class="service-card">
                    <div class="service-icon">📄</div>
                    <h4>Contratos</h4>
                    <p>Gestiona los contratos y documentos.</p>
                </a>
                <a href="#" onclick="switchMainTab('tareas'); return false;" class="service-card">
                    <div class="service-icon">✅</div>
                    <h4>Tareas</h4>
                    <p>Organiza y asigna tareas del hogar.</p>
                </a>
                <a href="#" onclick="switchMainTab('gastos'); return false;" class="service-card">
                    <div class="service-icon">💶</div>
                    <h4>Gastos</h4>
                    <p>Controla los gastos y pagos del piso.</p>
                </a>
                <a href="#" onclick="switchMainTab('reservas'); return false;" class="service-card">
                    <div class="service-icon">📅</div>
                    <h4>Reservas</h4>
                    <p>Reserva zonas y espacios comunes.</p>
                </a>
                <a href="#" class="service-card">
                    <div class="service-icon">🔔</div>
                    <h4>Notificaciones</h4>
                    <p>Mantente al día con todo lo importante.</p>
                </a>
            </div>
            
            <div class="flat-card">
                <h3 style="font-size: 1.1rem; margin-bottom: 16px; color: #1e3a8a;">Resumen del mes</h3>
                <div class="summary-grid">
                    <div class="summary-item">
                        <div class="label">Gastos totales</div>
                        <div class="value">450 €</div>
                        <div class="trend">+12% que el mes pasado</div>
                    </div>
                    <div class="summary-item">
                        <div class="label">Tareas completadas</div>
                        <div class="value">12</div>
                        <div class="trend" style="color:#6b7280">+3 esta semana</div>
                    </div>
                    <div class="summary-item">
                        <div class="label">Incidencias abiertas</div>
                        <div class="value" style="color:#ef4444">2</div>
                        <div class="trend" style="color:#ef4444">-1 que el mes pasado</div>
                    </div>
                    <div class="summary-item">
                        <div class="label">Reservas este mes</div>
                        <div class="value">5</div>
                        <div class="trend" style="color:#3b82f6"><a href="#" onclick="switchMainTab('reservas')">Ver calendario</a></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB FUNCIONES (ONLY USED IF NOT LOGGED IN) -->
        <div id="tab-funciones" class="tab-content flat-card">
            <h2 style="margin-bottom:24px; color:#1e3a8a;">Funciones de FlatManager</h2>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
                <div><strong>✅ Gestión de Tareas</strong><p style="color:#6b7280;">Asigna turnos de limpieza de forma equitativa.</p></div>
                <div><strong>💶 Control de Gastos</strong><p style="color:#6b7280;">Registra facturas y divide automáticamente.</p></div>
                <div><strong>📅 Reservas</strong><p style="color:#6b7280;">Evita conflictos reservando la lavadora o la ducha.</p></div>
                <div><strong>📄 Contratos</strong><p style="color:#6b7280;">Documentos y pagos siempre a mano.</p></div>
            </div>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>

        <!-- TAB PLANES (PREVIOUS FOOTER PRICING) -->
        <div id="tab-planes" class="tab-content flat-card">
            <h2 style="margin-bottom:24px; text-align:center; color:#1e3a8a;">Planes de Suscripción</h2>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; text-align:center;">
                <div style="border:1px solid #e5e7eb; padding:24px; border-radius:8px;">
                    <h3 style="margin-bottom:8px;">Basic</h3>
                    <h2 style="font-size:2rem; margin-bottom:16px;">0€ <span style="font-size:1rem;color:#6b7280">/mes</span></h2>
                    <a href="/Account/Upgrade?plan=Basico" class="btn btn-outline" style="width:100%">Elegir Basic</a>
                </div>
                <div style="border:2px solid #3b82f6; padding:24px; border-radius:8px; box-shadow:0 4px 6px rgba(0,0,0,0.05);">
                    <h3 style="margin-bottom:8px; color:#3b82f6;">Pro</h3>
                    <h2 style="font-size:2rem; margin-bottom:16px;">4.99€ <span style="font-size:1rem;color:#6b7280">/mes</span></h2>
                    <a href="/Account/Upgrade?plan=Profesional" class="btn btn-primary" style="width:100%">Elegir Pro</a>
                </div>
                <div style="border:1px solid #e5e7eb; padding:24px; border-radius:8px;">
                    <h3 style="margin-bottom:8px;">Enterprise</h3>
                    <h2 style="font-size:2rem; margin-bottom:16px;">19.99€ <span style="font-size:1rem;color:#6b7280">/mes</span></h2>
                    <a href="/Account/Upgrade?plan=Enterprise" class="btn btn-outline" style="width:100%">Contactar</a>
                </div>
            </div>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:24px;">← Volver</button>
        </div>

        <!-- MOCK TABS FOR THE UI DEMO -->
        <div id="tab-pisos" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Mis pisos</h2>
            <p>Aquí se listarán tus pisos gestionados con la estructura MVC. <a href="/Dashboard/MisPisos">Ir a Dashboard/MisPisos</a></p>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
        <div id="tab-tareas" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Tareas del hogar</h2>
            <p>Lista interactiva de tareas pendientes... <a href="/Dashboard/Tareas">Ir a Dashboard/Tareas</a></p>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
        <div id="tab-gastos" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Gastos del mes</h2>
            <p>Control de gastos detallado... <a href="/Dashboard/Gastos">Ir a Dashboard/Gastos</a></p>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
        <div id="tab-contratos" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Contratos y Pagos</h2>
            <p>Gestión de documentos integrados con ADO.NET.</p>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
        <div id="tab-reservas" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Reservas de zonas comunes</h2>
            <p>Calendario y disponibilidad...</p>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
        <div id="tab-mensajes" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Mensajes</h2>
            <p>Bandeja de entrada de comunicaciones...</p>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
        <div id="tab-perfil" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">Mi Perfil</h2>
            <p>Edita tus datos, sube una foto, revisa tu plan...</p>
            <a href="/Account/Upgrade?plan=Profesional" class="btn btn-primary">Actualizar Plan</a>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>
    </div>

    <!-- RIGHT FIXED ADVERTISEMENTS (PUBLICIDAD) -->
    @if (!isLoggedIn || Context.Session.GetString("UserRole") == "Basico")
    {
        <div class="sidebar-right">
            <div class="flat-card" style="background: linear-gradient(to bottom, #1e3a8a, #3b82f6); color: white; padding: 24px; text-align: center;">
                <h3 style="font-size: 1.2rem; margin-bottom: 8px;">Limpieza a domicilio</h3>
                <p style="font-size: 0.85rem; color: #dbeafe; margin-bottom: 16px;">Deja tu piso impecable.</p>
                <button class="btn btn-outline btn-sm" style="color:white; border-color:rgba(255,255,255,0.4);">Ver ofertas</button>
            </div>
            
            <div class="flat-card" style="background: #ecfdf5; border-color: #a7f3d0; padding: 24px; text-align: center;">
                <h3 style="font-size: 1.2rem; color: #065f46; margin-bottom: 8px;">Muebles para compartir</h3>
                <p style="font-size: 0.85rem; color: #047857; margin-bottom: 16px;">Precios increíbles para nuevas camas y escritorios.</p>
                <button class="btn btn-primary btn-sm" style="background:#10b981;">Descubrir</button>
            </div>
        </div>
    }
</div>

<script>
    function switchMainTab(tabId) {
        // Enforce SPA UI paradigm for FlatManager structure
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
        
        var targetSection = document.getElementById('tab-' + tabId);
        if(targetSection) {
            targetSection.classList.add('active');
        }
        
        // Match nav links globally to add bold/active style
        var relatedNav = document.querySelector('a.nav-link[onclick*="' + tabId + '"]');
        if(relatedNav) relatedNav.classList.add('active');
    }
</script>
