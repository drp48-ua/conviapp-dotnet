<script>
    function switchMainTab(tabId) {
        // Enforce SPA UI paradigm for FlatManager structure
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
        
        var targetSection = document.getElementById('tab-' + tabId);
        if(targetSection) {
            targetSection.classList.add('active');
        }
        
        // Match nav links globally to add bold/active style
        var relatedNav = document.querySelectorAll('a.nav-link[onclick*="' + tabId + '"]');
        if(relatedNav) relatedNav.forEach(el => el.classList.add('active'));
        
        // Update URL hash for sharing/back button friendly
        if(history.pushState) {
            history.pushState(null, null, '#' + 'tab-' + tabId);
        } else {
            location.hash = '#tab-' + tabId;
        }
    }

    // Auto-open tab on load if hash is present
    document.addEventListener('DOMContentLoaded', function() {
        if (window.location.hash) {
            var tabId = window.location.hash.replace('#tab-', '');
            if (document.getElementById('tab-' + tabId)) {
                switchMainTab(tabId);
            }
        }
    });

    // Support browser back/forward buttons
    window.addEventListener('hashchange', function() {
        if (window.location.hash) {
            var tabId = window.location.hash.replace('#tab-', '');
            if (document.getElementById('tab-' + tabId)) {
                switchMainTab(tabId);
            }
        } else {
            switchMainTab('inicio');
        }
    });
</script>
