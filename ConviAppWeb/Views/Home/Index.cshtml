<script>
    function switchMainTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
        document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
        
        var targetSection = document.getElementById('tab-' + tabId);
        if (targetSection) targetSection.classList.add('active');
        
        // Activate the matching nav link by its id (e.g. navTareas)
        var navId = 'nav' + tabId.charAt(0).toUpperCase() + tabId.slice(1);
        var navEl = document.getElementById(navId);
        if (navEl) navEl.classList.add('active');
        else document.getElementById('navInicio')?.classList.add('active');

        // Update URL without reload
        history.replaceState(null, '', tabId === 'inicio' ? '/' : '/?tab=' + tabId);
    }

    // Auto-switch to tab from ?tab= query param on page load
    document.addEventListener('DOMContentLoaded', function () {
        var params = new URLSearchParams(window.location.search);
        var tab = params.get('tab');
        if (tab) switchMainTab(tab);
        else document.getElementById('navInicio')?.classList.add('active');
    });
</script>
