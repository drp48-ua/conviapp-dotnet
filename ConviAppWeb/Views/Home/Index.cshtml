@model List<ConviAppWeb.Models.ENPiso>
@{
    ViewData["Title"] = "Inicio";
    ViewData["ActivePage"] = "Home";
    
    // Check if user logged in
    var userEmail = Context.Session.GetString("UserEmail");
    bool isLoggedIn = userEmail != null;
}

<style>
    /* Specific FlatManager Layout Styles */
    .dashboard-layout {
        display: flex;
        gap: 24px;
        padding-top: 24px;
        max-width: 1400px;
        margin: 0 auto;
    }
    .sidebar-left {
        width: 250px;
        flex-shrink: 0;
    }
    .main-content {
        flex: 1;
        min-width: 0;
    }
    .sidebar-right {
        width: 300px;
        flex-shrink: 0;
    }
    
    .flat-card {
        background: white;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        padding: 20px;
        margin-bottom: 24px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    
    .profile-card { text-align: center; }
    .profile-card img { width: 64px; height: 64px; border-radius: 50%; margin-bottom: 12px; }
    .profile-card h4 { margin: 0 0 4px; font-size: 1.1rem; }
    .profile-card p { color: #6b7280; font-size: 0.85rem; margin-bottom: 16px; }
    
    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        color: #4b5563;
        text-decoration: none;
        border-radius: 6px;
        font-weight: 500;
        margin-bottom: 4px;
    }
    .menu-link:hover { background: #f3f4f6; color: #1e3a8a; }
    
    .welcome-banner {
        background: linear-gradient(135deg, #f0f4f8, #e0e7ff);
        border: 1px solid #c7d2fe;
        border-radius: 8px;
        padding: 32px;
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .welcome-banner h2 { margin: 0 0 8px; color: #1e3a8a; }
    .welcome-banner p { color: #4b5563; margin-bottom: 20px; max-width: 600px; }
    
    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }
    .service-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        text-align: center;
        transition: all 0.2s;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: inherit;
    }
    .service-card:hover { border-color: #3b82f6; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .service-icon { font-size: 2rem; margin-bottom: 12px; }
    .service-card h4 { margin: 0 0 8px; font-size: 1rem; color: #1f2937; }
    .service-card p { font-size: 0.8rem; color: #6b7280; margin: 0; line-height: 1.4; }
    
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }
    .summary-item {
        background: #f9fafb;
        border: 1px solid #f3f4f6;
        border-radius: 8px;
        padding: 16px;
    }
    .summary-item .label { font-size: 0.85rem; color: #6b7280; font-weight: 500; }
    .summary-item .value { font-size: 1.5rem; font-weight: 700; color: #111827; margin: 4px 0; }
    .summary-item .trend { font-size: 0.75rem; color: #10b981; font-weight: 500; }
    
    .tab-content { display: none; }
    .tab-content.active { display: block; animation: fadeIn 0.3s ease; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="dashboard-layout">
    @if (isLoggedIn)
    {
        <!-- RIGHT LOGGED IN SIDEBAR -->
        <div class="sidebar-left">
            <div class="flat-card profile-card" style="text-align:center;">
                <img src="https://ui-avatars.com/api/?name=U&background=f3f4f6&color=1e3a8a&rounded=true&size=128" alt="Usuario" style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 12px; display: block;" />
                <h4 style="margin-bottom: 4px;">Hola, @(userEmail?.Split('@')[0] ?? "Usuario")</h4>
                <p style="color:var(--text-muted); font-size:0.85rem; margin-bottom:16px;">@userEmail</p>
                <a href="#" onclick="switchMainTab('perfil'); return false;" class="btn btn-outline btn-sm" style="width:100%; justify-content:center;">Editar perfil</a>
            </div>
            
            <div class="flat-card" style="padding: 16px;">
                <h4 style="font-size: 0.9rem; color: #6b7280; margin-bottom: 12px; font-weight: 600; text-transform: uppercase;">Accesos rápidos</h4>
                <a href="#" onclick="switchMainTab('tareas'); return false;" class="menu-link"><span>✅</span> Mis tareas</a>
                <a href="#" onclick="switchMainTab('gastos'); return false;" class="menu-link"><span>💶</span> Mis gastos</a>
                <a href="#" class="menu-link"><span>🔧</span> Nueva incidencia</a>
                <a href="#" onclick="switchMainTab('reservas'); return false;" class="menu-link"><span>📅</span> Calendario</a>
            </div>
        </div>
    }

    <!-- MAIN INTERACTIVE AREA -->
    <div class="main-content">
        <!-- TAB INICIO -->
        <div id="tab-inicio" class="tab-content active">
            @if (isLoggedIn)
            {
                <div class="welcome-banner" style="background: url('https://images.unsplash.com/photo-1556910103-1c02745aae4f?q=80&w=1500&auto=format&fit=crop') center/cover; position:relative; overflow:hidden;">
                    <div style="position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(90deg, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0.8) 100%); z-index:1;"></div>
                    <div style="position:relative; z-index:2; width:100%;">
                        <h2 style="color: #1e3a8a !important; margin-bottom:8px; font-size: 2rem;">¡Bienvenida a ConviApp!</h2>
                        <p style="color: #4b5563 !important; max-width: 500px; font-size:1.1rem; margin-bottom:20px;">La forma más fácil de gestionar tu piso compartido de manera organizada y eficiente.</p>
                        <div style="display: flex; gap: 12px;">
                            <a href="/Dashboard/MisPisos" class="btn btn-primary">Ver mis pisos</a>
                            <a href="/Dashboard/Tareas" class="btn btn-outline" style="background:white; color:#1e3a8a;">Ir a mis tareas</a>
                        </div>
                    </div>
                </div>
                
                <h3 style="font-size: 1.1rem; margin-bottom: 16px; color: #1e3a8a !important;">Servicios principales</h3>
                <div class="services-grid">
                    <a href="#" onclick="switchMainTab('pisos'); return false;" class="service-card" style="border: 1px solid var(--border);">
                        <div class="service-icon" style="color: #3b82f6;">🏠</div>
                        <h4>Pisos</h4>
                        <p>Consulta y gestiona pisos disponibles.</p>
                        <span style="font-size: 0.75rem; color: #3b82f6; margin-top:8px; font-weight:600;">Ver pisos →</span>
                    </a>
                    <a href="#" onclick="switchMainTab('contratos'); return false;" class="service-card" style="border: 1px solid var(--border);">
                        <div class="service-icon" style="color: #10b981;">📄</div>
                        <h4>Contratos</h4>
                        <p>Documentos y pagos del piso.</p>
                        <span style="font-size: 0.75rem; color: #10b981; margin-top:8px; font-weight:600;">Ver contratos →</span>
                    </a>
                    <a href="#" onclick="switchMainTab('tareas'); return false;" class="service-card" style="border: 1px solid var(--border);">
                        <div class="service-icon" style="color: #f59e0b;">✅</div>
                        <h4>Tareas</h4>
                        <p>Organiza roles del hogar.</p>
                        <span style="font-size: 0.75rem; color: #f59e0b; margin-top:8px; font-weight:600;">Ver tareas →</span>
                    </a>
                    <a href="#" onclick="switchMainTab('gastos'); return false;" class="service-card" style="border: 1px solid var(--border);">
                        <div class="service-icon" style="color: #8b5cf6;">💶</div>
                        <h4>Gastos</h4>
                        <p>Controla los pagos.</p>
                        <span style="font-size: 0.75rem; color: #8b5cf6; margin-top:8px; font-weight:600;">Ver gastos →</span>
                    </a>
                    <a href="#" onclick="switchMainTab('reservas'); return false;" class="service-card" style="border: 1px solid var(--border);">
                        <div class="service-icon" style="color: #06b6d4;">📅</div>
                        <h4>Reservas</h4>
                        <p>Reserva zonas comunes.</p>
                        <span style="font-size: 0.75rem; color: #06b6d4; margin-top:8px; font-weight:600;">Ver reservas →</span>
                    </a>
                    <a href="#" onclick="switchMainTab('mensajes'); return false;" class="service-card" style="border: 1px solid var(--border);">
                        <div class="service-icon" style="color: #f43f5e;">🔔</div>
                        <h4>Notificaciones</h4>
                        <p>Mensajes e incidencias.</p>
                        <span style="font-size: 0.75rem; color: #f43f5e; margin-top:8px; font-weight:600;">Ver todas →</span>
                    </a>
                </div>
                
                <div style="display:grid; grid-template-columns: 2fr 1fr; gap:24px; margin-bottom:24px;">
                    <div class="flat-card" style="margin-bottom:0;">
                        <h3 style="font-size: 1.1rem; margin-bottom: 16px; color: #1e3a8a !important;">Resumen del mes</h3>
                        <div class="summary-grid" style="grid-template-columns: 1fr 1fr; margin-bottom:0;">
                            <div class="summary-item">
                                <div class="label">Gastos totales</div>
                                <div class="value">450 €</div>
                                <div class="trend">+12% que el mes pasado</div>
                            </div>
                            <div class="summary-item">
                                <div class="label">Tareas completadas</div>
                                <div class="value">12</div>
                                <div class="trend" style="color:#6b7280">+3 esta semana</div>
                            </div>
                            <div class="summary-item">
                                <div class="label">Incidencias abiertas</div>
                                <div class="value" style="color:#ef4444 !important;">2</div>
                                <div class="trend" style="color:#ef4444">-1 que el mes pasado</div>
                            </div>
                            <div class="summary-item">
                                <div class="label">Reservas este mes</div>
                                <div class="value">5</div>
                                <div class="trend" style="color:#3b82f6"><a href="#" onclick="switchMainTab('reservas'); return false;">Ver calendario</a></div>
                            </div>
                        </div>
                    </div>
                    <div class="flat-card" style="margin-bottom:0;">
                         <h3 style="font-size: 1.1rem; margin-bottom: 16px; color: #1e3a8a !important;">Última actividad</h3>
                         <ul style="list-style:none; padding:0; margin:0;">
                             <li style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); padding:8px 0; font-size:0.85rem;">
                                 <div><span style="color:#3b82f6; margin-right:6px;">◉</span> Has pagado el gasto de luz</div>
                                 <div style="color:var(--text-muted) !important; font-size:0.75rem;">Hace 2 h</div>
                             </li>
                             <li style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); padding:8px 0; font-size:0.85rem;">
                                 <div><span style="color:#10b981; margin-right:6px;">◉</span> Incidencia: Fregadero...</div>
                                 <div style="color:var(--text-muted) !important; font-size:0.75rem;">Hace 5 h</div>
                             </li>
                             <li style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; font-size:0.85rem;">
                                 <div style="text-decoration:line-through; color:var(--text-muted) !important;"><span style="color:var(--border); margin-right:6px;">○</span> Tarea completada: Baño</div>
                                 <div style="color:var(--text-muted) !important; font-size:0.75rem;">Ayer</div>
                             </li>
                         </ul>
                    </div>
                </div>

                <div class="welcome-banner" style="display:flex; justify-content:space-between; align-items:center; background:#f0f9ff; border:1px solid #bae6fd; padding:32px; border-radius:8px;">
                     <div>
                         <h3 style="color:#0369a1 !important; margin:0 0 8px; font-size:1.5rem;">¿Necesitas muebles para tu piso?</h3>
                         <p style="margin:0; font-size:1rem; color:#0c4a6e !important;">Descuentos exclusivos para pisos compartidos en IKEA y Maisons du Monde.</p>
                     </div>
                     <button class="btn btn-primary" style="background:#0ea5e9; border:none;">Ver ofertas</button>
                </div>
            }
            else
            {
                <!-- MARKETING LANDING PREVIEW WHEN NOT LOGGED IN -->
                <div class="welcome-banner" style="text-align:center; display:block;">
                    <h2 style="font-size:2.5rem; margin-bottom:16px; color: #1e3a8a !important;">La convivencia inteligente empieza aquí</h2>
                    <p style="margin:0 auto 24px;">Gestiona tu piso compartido de forma sencilla: tareas, gastos, reservas y comunicación.</p>
                    <a href="/Account/Register" class="btn btn-primary btn-lg">Empezar gratis</a>
                </div>
                
                <h3 style="text-align:center; margin: 40px 0 20px;">Explora la plataforma</h3>
                <div class="services-grid" style="justify-content:center;">
                    <button onclick="switchMainTab('funciones')" class="service-card">
                        <div class="service-icon">✨</div>
                        <h4>Funciones</h4>
                        <p>Todo lo que necesitas</p>
                    </button>
                    <button onclick="switchMainTab('planes')" class="service-card">
                        <div class="service-icon">💎</div>
                        <h4>Planes</h4>
                        <p>Opciones para todos</p>
                    </button>
                    <a href="/Home/Pisos" class="service-card">
                        <div class="service-icon">🏙️</div>
                        <h4>Catálogo</h4>
                        <p>Ver pisos disponibles</p>
                    </a>
                </div>
            }
        </div>

        <!-- TAB FUNCIONES (ONLY USED IF NOT LOGGED IN) -->
        <div id="tab-funciones" class="tab-content flat-card">
            <h2 style="margin-bottom:24px; color:#1e3a8a;">Funciones de FlatManager</h2>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
                <div><strong>✅ Gestión de Tareas</strong><p style="color:#6b7280;">Asigna turnos de limpieza de forma equitativa.</p></div>
                <div><strong>💶 Control de Gastos</strong><p style="color:#6b7280;">Registra facturas y divide automáticamente.</p></div>
                <div><strong>📅 Reservas</strong><p style="color:#6b7280;">Evita conflictos reservando la lavadora o la ducha.</p></div>
                <div><strong>📄 Contratos</strong><p style="color:#6b7280;">Documentos y pagos siempre a mano.</p></div>
            </div>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:20px;">← Volver</button>
        </div>

        <!-- TAB PLANES (PREVIOUS FOOTER PRICING) -->
        <div id="tab-planes" class="tab-content flat-card">
            <h2 style="margin-bottom:24px; text-align:center; color:#1e3a8a;">Planes de Suscripción</h2>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; text-align:center;">
                <div style="border:1px solid #e5e7eb; padding:24px; border-radius:8px;">
                    <h3 style="margin-bottom:8px;">Basic</h3>
                    <h2 style="font-size:2rem; margin-bottom:16px;">0€ <span style="font-size:1rem;color:#6b7280">/mes</span></h2>
                    <a href="/Account/Upgrade?plan=Basico" class="btn btn-outline" style="width:100%">Elegir Basic</a>
                </div>
                <div style="border:2px solid #3b82f6; padding:24px; border-radius:8px; box-shadow:0 4px 6px rgba(0,0,0,0.05);">
                    <h3 style="margin-bottom:8px; color:#3b82f6;">Pro</h3>
                    <h2 style="font-size:2rem; margin-bottom:16px;">4.99€ <span style="font-size:1rem;color:#6b7280">/mes</span></h2>
                    <a href="/Account/Upgrade?plan=Profesional" class="btn btn-primary" style="width:100%">Elegir Pro</a>
                </div>
                <div style="border:1px solid #e5e7eb; padding:24px; border-radius:8px;">
                    <h3 style="margin-bottom:8px;">Enterprise</h3>
                    <h2 style="font-size:2rem; margin-bottom:16px;">19.99€ <span style="font-size:1rem;color:#6b7280">/mes</span></h2>
                    <a href="/Account/Upgrade?plan=Enterprise" class="btn btn-outline" style="width:100%">Contactar</a>
                </div>
            </div>
            <button onclick="switchMainTab('inicio')" class="btn btn-outline" style="margin-top:24px;">← Volver</button>
        </div>

        <!-- MOCK TABS FOR THE UI DEMO -->
        <div id="tab-pisos" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">🏢 Tus Propiedades</h2>
            <div class="dash-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 24px;">
                <div class="dash-stat" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), transparent);">
                    <div class="icon">🏘️</div>
                    <div class="value">2</div>
                    <div class="label">Pisos Registrados</div>
                </div>
                <div class="dash-stat" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), transparent);">
                    <div class="icon">✅</div>
                    <div class="value">100%</div>
                    <div class="label">Ocupación Actual</div>
                </div>
            </div>
            <div class="glass-card" style="padding:0; overflow:hidden; border: 1px solid var(--border);">
                <table class="data-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead style="background: var(--bg-input);">
                        <tr><th style="padding:12px 16px;">Dirección</th><th style="padding:12px 16px;">Ciudad</th><th style="padding:12px 16px;">Habitaciones</th><th style="padding:12px 16px;">Mantenimiento</th></tr>
                    </thead>
                    <tbody>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 16px; font-weight: 500;">Av. Marni, 14, 2A</td>
                            <td style="padding: 12px 16px;">Valencia</td>
                            <td style="padding: 12px 16px;">🛏️ 3 hab.</td>
                            <td style="padding: 12px 16px;"><span class="status-badge" style="background:rgba(16, 185, 129, 0.1); color:#10b981;">Al día</span></td>
                        </tr>
                        <tr>
                            <td style="padding: 12px 16px; font-weight: 500;">Calle Mayor, 100</td>
                            <td style="padding: 12px 16px;">Alicante</td>
                            <td style="padding: 12px 16px;">🛏️ 4 hab.</td>
                            <td style="padding: 12px 16px;"><span class="status-badge pending">1 Incidencia</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top: 24px;">
                <p style="color:var(--text-muted); margin:0; font-size:0.9rem;">(Demo) Regístrate para añadir tus propios pisos reales.</p>
                <a href="/Account/Register" class="btn btn-primary btn-sm">Añadir piso</a>
            </div>
        </div>

        <div id="tab-tareas" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">✅ Tareas del Hogar</h2>
            <ul class="task-list">
                <li class="task-item">
                    <span style="font-size: 1.2rem;">🧹</span>
                    <div class="task-info">
                        <div class="task-name">Limpieza de baño semanal</div>
                        <div class="task-meta">Asignado a: Carlos · Vence hoy</div>
                    </div>
                    <span class="status-badge pending">Pendiente</span>
                </li>
                <li class="task-item">
                    <span style="font-size: 1.2rem;">🗑️</span>
                    <div class="task-info">
                        <div class="task-name">Bajar la basura y reciclaje</div>
                        <div class="task-meta">Asignado a: Lucía · Vence mañana</div>
                    </div>
                    <span class="status-badge pending">Pendiente</span>
                </li>
                <li class="task-item completed" style="opacity: 0.7;">
                    <span style="font-size: 1.2rem;">🍽️</span>
                    <div class="task-info">
                        <div class="task-name" style="text-decoration: line-through;">Limpiar la cocina a fondo</div>
                        <div class="task-meta">Completado por: Dani</div>
                    </div>
                    <span class="status-badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">Hecho</span>
                </li>
            </ul>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top: 24px;">
                <p style="color:var(--text-muted); margin:0; font-size:0.9rem;">(Demo) Evita peleas: centraliza turnos y avisos.</p>
                <a href="/Account/Register" class="btn btn-primary btn-sm">Probar Tareas Gratis</a>
            </div>
        </div>

        <div id="tab-gastos" class="tab-content flat-card">
            <h2 style="margin-bottom:16px;">💶 Centro de Gastos</h2>
            <div class="dash-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 24px;">
                <div class="dash-stat">
                    <div class="icon">⚡</div>
                    <div class="value">84.50 €</div>
                    <div class="label">Recibo Luz (Enero)</div>
                </div>
                <div class="dash-stat">
                    <div class="icon">💧</div>
                    <div class="value">32.20 €</div>
                    <div class="label">Recibo Agua</div>
                </div>
            </div>
            <div class="glass-card" style="padding:0; overflow:hidden; border: 1px solid var(--border);">
                <table class="data-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead style="background: var(--bg-input);">
                        <tr><th style="padding:12px 16px;">Concepto</th><th style="padding:12px 16px;">Importe Total</th><th style="padding:12px 16px;">Tu Parte</th><th style="padding:12px 16px;">Estado</th></tr>
                    </thead>
                    <tbody>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 12px 16px; font-weight: 500;">Factura Iberdrola</td>
                            <td style="padding: 12px 16px;">84.50 €</td>
                            <td style="padding: 12px 16px; font-weight: bold; color: var(--danger);">21.12 €</td>
                            <td style="padding: 12px 16px;"><span class="status-badge pending">A Pagar</span></td>
                        </tr>
                        <tr>
                            <td style="padding: 12px 16px; font-weight: 500;">Compra Supermercado común</td>
