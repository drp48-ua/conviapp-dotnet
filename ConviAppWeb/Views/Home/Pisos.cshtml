@model List<ConviAppWeb.Models.ENPiso>
@{
    ViewData["Title"] = "Catálogo de Pisos";
    ViewData["ActivePage"] = "Pisos";
    var city = Context.Request.Query["ciudad"].ToString();
    var minPrice = Context.Request.Query["min"].ToString();
    var maxPrice = Context.Request.Query["max"].ToString();

    var filtered = Model ?? new List<ConviAppWeb.Models.ENPiso>();
    if (!string.IsNullOrWhiteSpace(city))
        filtered = filtered.Where(p => p.Ciudad != null && p.Ciudad.Contains(city, StringComparison.OrdinalIgnoreCase)).ToList();
    if (decimal.TryParse(minPrice, out var mn))
        filtered = filtered.Where(p => p.PrecioTotal >= mn).ToList();
    if (decimal.TryParse(maxPrice, out var mx))
        filtered = filtered.Where(p => p.PrecioTotal <= mx).ToList();
}

<div class="container" style="padding-top: 2rem; padding-bottom: 4rem;">
    <!-- Header -->
    <div style="margin-bottom: 32px;">
        <h1 style="font-size: 2.5rem; margin-bottom: 8px;">Encuentra tu piso ideal</h1>
        <p style="color: var(--text-muted);">@Model?.Count piso@(Model?.Count != 1 ? "s" : "") disponibles en la plataforma.</p>
    </div>

    <!-- Filters -->
    <form method="get" action="/Home/Pisos">
        <div class="glass-card" style="margin-bottom: 32px; padding: 20px;">
            <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: end;">
                <div style="flex: 2; min-width: 160px;">
                    <label style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 4px; display: block;">📍 Ciudad</label>
                    <input type="text" name="ciudad" value="@city" class="form-input" placeholder="Ej: Madrid, Valencia..." />
                </div>
                <div style="flex: 1; min-width: 120px;">
                    <label style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 4px; display: block;">€ Precio mín.</label>
                    <input type="number" name="min" value="@minPrice" class="form-input" placeholder="0" step="50" />
                </div>
                <div style="flex: 1; min-width: 120px;">
                    <label style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 4px; display: block;">€ Precio máx.</label>
                    <input type="number" name="max" value="@maxPrice" class="form-input" placeholder="2000" step="50" />
                </div>
                <button type="submit" class="btn btn-primary btn-sm" style="align-self: flex-end;">Buscar</button>
                @if (!string.IsNullOrWhiteSpace(city) || !string.IsNullOrWhiteSpace(minPrice) || !string.IsNullOrWhiteSpace(maxPrice))
                {
                    <a href="/Home/Pisos" class="btn btn-outline btn-sm" style="align-self: flex-end;">✕ Limpiar</a>
                }
            </div>
        </div>
    </form>

    <p style="color: var(--text-muted); margin-bottom: 24px; font-size: 0.9rem;">
        Mostrando <strong style="color: var(--text-primary);">@filtered.Count</strong> piso@(filtered.Count != 1 ? "s" : "")@(!string.IsNullOrWhiteSpace(city) ? $" en {city}" : "")
    </p>

    @if (!filtered.Any())
    {
        <div class="glass-card" style="text-align: center; padding: 4rem; color: var(--text-muted);">
            <div style="font-size: 3rem; margin-bottom: 16px;">🏚️</div>
            <h3>Sin resultados</h3>
            <p>No hemos encontrado pisos con esos filtros.</p>
            <a href="/Home/Pisos" class="btn btn-primary btn-sm" style="margin-top: 16px;">Ver todos los pisos →</a>
        </div>
    }
    else
    {
        <div class="listings-grid">
            @foreach (var piso in filtered)
            {
                <a href="/Home/PisoDetail/@piso.Id" class="listing-card">
                    <div class="listing-img" style="position:relative; overflow:hidden;">
                        <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=600&q=80" style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover;" alt="Portada Piso" />
                        <span class="listing-badge">@(piso.Disponible ? "Disponible" : "Ocupado")</span>
                        <button class="wishlist-btn" onclick="event.preventDefault();">♡</button>
                    </div>
                    <div class="listing-body">
                        <div class="listing-price">@piso.PrecioTotal.ToString("0")€ <span>/mes</span></div>
                        <div class="listing-title">@(piso.Direccion ?? "Piso")</div>
                        <div class="listing-location">📍 @(piso.Ciudad ?? "Ciudad")</div>
                        <div class="listing-tags">
                            <span class="listing-tag">🛏️ @piso.NumeroHabitaciones hab.</span>
                            <span class="listing-tag listing-tag-arrow">Ver detalles →</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>
