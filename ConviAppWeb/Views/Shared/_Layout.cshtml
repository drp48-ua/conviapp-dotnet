<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="ConviApp — Gestión inteligente de piso compartido. Tareas, gastos, reservas y comunicación en una sola plataforma." />
    <title>@ViewData["Title"] - ConviApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css?v=2026.4" />
    <style>
        /* CSS FORZADO PARA PREVENIR ERROR DE CACHE O DARK MODE EN RENDER */
        .page-wrapper {
            padding-top: 130px !important; 
        }
        .header-bottom {
            background: #1e3a8a !important; 
        }
        .header-bottom a.nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
        }
        .header-bottom a.nav-link.active, .header-bottom a.nav-link:hover {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #ffffff !important;
        }
        
        /* Contraste forzado para tarjetas blancas (evita texto invisible en dark mode) */
        .flat-card {
            background: #ffffff !important;
            color: #111827 !important;
        }
        .flat-card h2, .flat-card h3, .flat-card h4, .dash-stat .value, .data-table th, .data-table td, .task-info .task-name {
            color: #111827 !important;
        }
        .dash-stat .label, .task-meta, .flat-card p {
            color: #4b5563 !important;
        }
        .status-badge {
            color: #111827 !important;
        }
    </style>
</head>
<body>
    <!-- ═══ FIXED HEADER ═══ -->
    <header class="header">
        <div class="header-top container" style="max-width:100%; width:100%">
            <a href="/" class="logo" style="flex-direction:row; align-items:center;">
                <div class="logo-icon" style="background:white; color:var(--primary); font-size:1.5rem">🏠</div>
                <div style="line-height: 1.1;">
                    <div style="font-size: 1.25rem;">ConviApp</div>
                    <div style="font-size: 0.65rem; font-weight: 500; opacity: 0.8; text-transform: uppercase;">Gestión de Piso Compartido</div>
                </div>
            </a>
            
            <div style="flex:1;"></div>

            <div class="header-actions">
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <div style="display:flex; align-items:center; gap:16px;">
                        <span style="color:white; font-size:1.2rem; position:relative;">
                            🔔
                            <span style="position:absolute; top:-4px; right:-4px; background:#ef4444; width:10px; height:10px; border-radius:50%;"></span>
                        </span>
                        <img src="https://ui-avatars.com/api/?name=U&background=ffffff&color=1e3a8a&rounded=true" alt="Avatar Genérico" style="width:36px; height:36px; border-radius:50%; object-fit:cover;">
                        <div style="color:white; font-size:0.9rem; line-height:1.2; text-align:right;">
                            <div style="font-weight:600;">Hola, @Context.Session.GetString("UserEmail")?.Split('@')[0]</div>
                            <a href="/Account/Logout" style="color:rgba(255,255,255,0.7); font-size:0.8rem; text-decoration:none;">Cerrar sesión</a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="/Account/Register" class="btn btn-outline btn-sm" style="color:white; border-color:rgba(255,255,255,0.3);">Registrarse</a>
                    <a href="/Account/Login" class="btn btn-sm" style="background:white; color:var(--primary); font-weight:600;">Acceder →</a>
                }
            </div>
        </div>
        <div class="header-bottom">
            <div class="container" style="display:flex; gap:8px; width:100%; max-width:100%;">
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <a href="/Dashboard/Index" class="nav-link">📊 General</a>
                    <a href="/Home/Pisos" class="nav-link">🏢 Catálogo</a>
                    <a href="/Dashboard/Tareas" class="nav-link">✅ Tareas</a>
                    <a href="/Dashboard/Gastos" class="nav-link">💶 Gastos</a>
                    <a href="/Dashboard/Reservas" class="nav-link">📅 Reservas</a>
                    <a href="/Dashboard/Incidencias" class="nav-link">🔧 Incidencias</a>
                    <a href="/Dashboard/ContratosYPagos" class="nav-link">📄 Contratos</a>
                    <a href="/Dashboard/Documentos" class="nav-link">📎 Documentos</a>
                    <a href="/Dashboard/MisPisos" class="nav-link">🏠 Mis Pisos</a>
                }
                else
                {
                    <a href="/#tab-inicio" class="nav-link active" onclick="if(window.switchMainTab) switchMainTab('inicio')">🏠 Inicio</a>
                    <a href="/Home/Pisos" class="nav-link">🏢 Pisos</a>
                    <a href="/#tab-contratos" class="nav-link" onclick="if(window.switchMainTab) switchMainTab('contratos')">📄 Contratos</a>
                    <a href="/#tab-tareas" class="nav-link" onclick="if(window.switchMainTab) switchMainTab('tareas')">✅ Tareas</a>
                    <a href="/#tab-gastos" class="nav-link" onclick="if(window.switchMainTab) switchMainTab('gastos')">💶 Gastos</a>
                    <a href="/#tab-reservas" class="nav-link" onclick="if(window.switchMainTab) switchMainTab('reservas')">📅 Reservas</a>
                    <a href="/#tab-mensajes" class="nav-link" onclick="if(window.switchMainTab) switchMainTab('mensajes')">✉️ Mensajes</a>
                }
            </div>
        </div>
    </header>

    <!-- ═══ PAGE CONTENT ═══ -->
    <div class="page-wrapper">
        @RenderBody()
    </div>

    @{
        var _layoutRole = Context.Session.GetString("UserRole") ?? "";
        var _showBottomAd = _layoutRole == "Basico";
    }
    @if (_showBottomAd)
    {
        <div class="container" style="padding: 0 24px 20px;">
            <div class="ad-slider-wrap ad-bottom">
                <div class="ad-label">PUBLICIDAD</div>
                <div class="ad-slider" id="adSliderB">
                    <div class="ad-slide active"><span class="ad-slide-icon">🏪</span><div class="ad-slide-body"><strong style="color:#f59e0b;">Carrefour Online</strong><span class="ad-slide-text">-5% en tu primera compra del mes. Entrega en 2h para pisos compartidos</span></div><a href="#" class="btn btn-sm ad-cta-btn" style="border-color:#f59e0b;color:#f59e0b;">Ver oferta</a></div>
                    <div class="ad-slide"><span class="ad-slide-icon">🧺</span><div class="ad-slide-body"><strong style="color:#06d6a0;">Lavandería24.es</strong><span class="ad-slide-text">Recogida y entrega de ropa en 24h. 3kg gratis el primer pedido</span></div><a href="#" class="btn btn-sm ad-cta-btn" style="border-color:#06d6a0;color:#06d6a0;">Probar</a></div>
                    <div class="ad-slide"><span class="ad-slide-icon">🔑</span><div class="ad-slide-body"><strong style="color:#818cf8;">TuCerrajero.es</strong><span class="ad-slide-text">Duplicado de llaves a domicilio desde 9.90€. Disponible 24/7</span></div><a href="#" class="btn btn-sm ad-cta-btn" style="border-color:#818cf8;color:#818cf8;">Solicitar</a></div>
                    <div class="ad-slide"><span class="ad-slide-icon">💇</span><div class="ad-slide-body"><strong style="color:#f87171;">Urban Wellness</strong><span class="ad-slide-text">Gimnasio compartido para pisos: 19.99€/mes. Incluye sauna y piscina</span></div><a href="#" class="btn btn-sm ad-cta-btn" style="border-color:#f87171;color:#f87171;">Apuntarse</a></div>
                    <div class="ad-slide"><span class="ad-slide-icon">📚</span><div class="ad-slide-body"><strong style="color:#34d399;">Wuolah.com</strong><span class="ad-slide-text">Apuntes universitarios gratis. Comparte los tuyos y gana dinero</span></div><a href="#" class="btn btn-sm ad-cta-btn" style="border-color:#34d399;color:#34d399;">Entrar</a></div>
                </div>
                <div class="ad-dots" id="adDotsB">
                    <span class="ad-dot active" onclick="goToAdB(0)"></span>
                    <span class="ad-dot" onclick="goToAdB(1)"></span>
                    <span class="ad-dot" onclick="goToAdB(2)"></span>
                    <span class="ad-dot" onclick="goToAdB(3)"></span>
                    <span class="ad-dot" onclick="goToAdB(4)"></span>
                </div>
                <div style="text-align:center;margin-top:8px;">
                    <a href="/#planes" style="color:var(--text-muted);font-size:0.7rem;text-decoration:underline;">💎 Actualiza a Pro para eliminar publicidad</a>
                </div>
            </div>
        </div>
        <script>
        (function(){
            let curB=0;
            const sB=document.querySelectorAll('#adSliderB .ad-slide');
            const dB=document.querySelectorAll('#adDotsB .ad-dot');
            function goToAdB(n){sB[curB].classList.remove('active');dB[curB].classList.remove('active');curB=(n+sB.length)%sB.length;sB[curB].classList.add('active');dB[curB].classList.add('active');}
            window.goToAdB=goToAdB;
            setInterval(()=>goToAdB(curB+1),5000);
        })();
        </script>
    }

    <!-- ═══ FOOTER ═══ -->
    <footer class="footer" style="background: var(--primary-dark); border-top: 1px solid rgba(255,255,255,0.1); padding: 16px 0; color: rgba(255,255,255,0.7); font-size: 0.85rem;">
        <div class="container" style="display: flex; justify-content: space-between; align-items: center; max-width: 100%;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 1.2rem;">🏠</span>
                <div>
                    <strong style="color: white; display:block;">ConviApp</strong>
                    <span style="font-size: 0.7rem;">Gestión de Piso Compartido</span>
                </div>
            </div>
            <div style="display: flex; gap: 24px;">
                <a href="#" style="color: rgba(255,255,255,0.7); text-decoration: none;">Quiénes somos</a>
                <span style="opacity:0.3">|</span>
                <a href="#" style="color: rgba(255,255,255,0.7); text-decoration: none;">Ayuda</a>
                <span style="opacity:0.3">|</span>
                <a href="#" style="color: rgba(255,255,255,0.7); text-decoration: none;">Contacto</a>
                <span style="opacity:0.3">|</span>
                <a href="#" style="color: rgba(255,255,255,0.7); text-decoration: none;">Términos y privacidad</a>
            </div>
            <div>
                © 2026 ConviApp
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
