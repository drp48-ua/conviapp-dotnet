@* Plan lock screen - shown when a feature is not available for the user's plan *@
<div class="glass-card" style="text-align: center; padding: 3rem;">
    <div style="font-size: 4rem; margin-bottom: 16px;">🔒</div>
    <h3 style="color: var(--primary-light); margin-bottom: 8px;">Función no disponible</h3>
    <p style="color: var(--text-muted); max-width: 400px; margin: 0 auto 20px;">
        Esta funcionalidad no está incluida en tu plan actual.
        Actualiza a <strong style="color: var(--accent);">Pro</strong> o
        <strong style="color: var(--warning);">Enterprise</strong> para desbloquearla.
    </p>
    <a href="/#planes" class="btn btn-primary">Ver Planes →</a>
</div>
